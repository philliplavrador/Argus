{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": false,
    "outDir": "out-test",
    "rootDir": ".",
    "sourceMap": false,
    "declaration": false
  },
  "include": ["src/lib", "test"]
}
