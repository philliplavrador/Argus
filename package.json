{
  "name": "argus",
  "displayName": "Argus",
  "description": "Run several Claude Code agents on one large repository at the same time — worktree isolation per task, scope enforcement at write time, one inbox for every agent's questions, and a serialized merge queue.",
  "version": "2.0.0",
  "publisher": "phillip-lavrador",
  "license": "MIT",
  "author": "Phillip Lavrador",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "workspaceContains:.argus"
  ],
  "contributes": {
    "commands": [
      {
        "command": "argus.open",
        "title": "Argus: Open Fleet Panel",
        "icon": "$(eye)"
      },
      {
        "command": "argus.init",
        "title": "Argus: Initialize Workspace"
      },
      {
        "command": "argus.collisionReport",
        "title": "Argus: Collision Report"
      },
      {
        "command": "argus.stopAll",
        "title": "Argus: Stop All Agents"
      },
      {
        "command": "argus.cleanupWorktrees",
        "title": "Argus: Clean Up Stale Worktrees"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "argus.open",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "compile": "npm run typecheck && node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "test": "tsc -p tsconfig.test.json && node --test \"out-test/test/*.test.js\""
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.214"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/vscode": "1.85.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0"
  }
}
